.page {
  padding: 32rpx 24rpx 80rpx;
}

/* 烟花层 */
.fireworks {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 8000;
  pointer-events: none;
}

.fw-burst {
  position: absolute;
  width: 0;
  height: 0;
}

.fw-particle {
  position: absolute;
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  opacity: 0;
  animation: fw-fly 1.1s cubic-bezier(0.15, 0.6, 0.4, 1) forwards;
}

@keyframes fw-fly {
  0% {
    opacity: 1;
    transform: translate(0, 0) scale(1.2);
  }
  70% {
    opacity: 1;
  }
  100% {
    opacity: 0;
    transform: translate(var(--dx), var(--dy)) scale(0.3);
  }
}

/* 开机动画 */
.splash {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 9999;
  display: flex;
  align-items: center;
  justify-content: center;
  background: radial-gradient(120% 120% at 50% 45%, #11161d 0%, var(--bg) 70%);
  animation: splash-bg-in 0.4s ease both;
}

.splash-glow {
  position: absolute;
  width: 560rpx;
  height: 560rpx;
  border-radius: 50%;
  background: radial-gradient(circle, var(--mint-glow) 0%, rgba(69, 230, 164, 0) 65%);
  opacity: 0.55;
  animation: splash-glow-pulse 1.6s ease-in-out infinite;
}

.splash-img {
  position: relative;
  width: 460rpx;
  height: 460rpx;
  transform-origin: 50% 30%;
  filter: drop-shadow(0 12rpx 48rpx rgba(0, 0, 0, 0.55));
  animation: splash-img-in 0.7s cubic-bezier(0.18, 0.89, 0.32, 1.28) both,
             splash-img-swing 0.45s ease-in-out 0.7s infinite;
}

.splash-tip {
  position: absolute;
  bottom: 18%;
  left: 0;
  right: 0;
  text-align: center;
  font-size: 26rpx;
  letter-spacing: 0.12em;
  color: var(--ink-soft);
  opacity: 0;
  animation: splash-tip-in 0.6s ease 0.9s forwards;
}

@keyframes splash-tip-in {
  from { opacity: 0; transform: translateY(12rpx); }
  to { opacity: 0.85; transform: translateY(0); }
}

@keyframes splash-img-swing {
  0%, 100% { transform: rotate(0deg); }
  25% { transform: rotate(-7deg); }
  75% { transform: rotate(7deg); }
}

/* 退场：遮罩淡出，图片放大旋转飞走，光晕爆开 */
.splash-leave {
  animation: splash-bg-out 0.7s ease 0.05s forwards;
}

.splash-leave .splash-img {
  animation: splash-img-out 0.7s cubic-bezier(0.55, 0, 0.85, 0.3) forwards;
}

.splash-leave .splash-glow {
  animation: splash-glow-burst 0.7s ease forwards;
}

@keyframes splash-bg-in {
  from { opacity: 0; }
  to { opacity: 1; }
}

@keyframes splash-bg-out {
  from { opacity: 1; }
  to { opacity: 0; }
}

@keyframes splash-img-in {
  0% { opacity: 0; transform: scale(0.4) translateY(40rpx); }
  100% { opacity: 1; transform: scale(1) translateY(0); }
}

@keyframes splash-img-out {
  0% { opacity: 1; transform: scale(1) rotate(0deg); }
  35% { opacity: 1; transform: scale(0.88) rotate(-8deg); }
  100% { opacity: 0; transform: scale(2.2) rotate(28deg); }
}

@keyframes splash-glow-pulse {
  0%, 100% { opacity: 0.4; transform: scale(0.92); }
  50% { opacity: 0.7; transform: scale(1.08); }
}

@keyframes splash-glow-burst {
  0% { opacity: 0.7; transform: scale(1); }
  100% { opacity: 0; transform: scale(3); }
}

/* 顶栏 */
.topbar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 40rpx;
}

.brand {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.brand-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: var(--mint);
  box-shadow: 0 0 16rpx var(--mint-glow);
}

.brand-text {
  font-size: 24rpx;
  letter-spacing: 0.18em;
  color: var(--ink-soft);
  font-weight: 500;
}

/* 活动主视觉 */
.hero {
  position: relative;
  display: flex;
  justify-content: center;
  padding: 16rpx 4rpx;
  margin-bottom: 28rpx;
}

.hero-main {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}

.hero-title {
  font-size: 56rpx;
  font-weight: 800;
  letter-spacing: 0.06em;
  color: var(--ink);
  line-height: 1.1;
  text-align: center;
  text-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.4);
}

.hero-tagline {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
}

.hero-rule {
  flex: none;
  width: 40rpx;
  height: 2rpx;
  background: linear-gradient(90deg, var(--mint-glow), transparent);
}

.hero-rule:last-child {
  background: linear-gradient(90deg, transparent, var(--mint-glow));
}

.hero-accent {
  font-size: 36rpx;
  font-weight: 700;
  letter-spacing: 0.36em;
  color: var(--mint);
  text-shadow: 0 0 32rpx var(--mint-glow);
}

/* 带操作按钮的标题行 */
.section-label-row {
  justify-content: space-between;
}

.section-label-main {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

/* 参数区 */
.param-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
  margin-bottom: 28rpx;
}

.param-cell {
  background: var(--card-soft);
  border-radius: 24rpx;
  padding: 24rpx 28rpx;
}

.param-label {
  font-size: 28rpx;
  color: var(--ink-soft);
  letter-spacing: 0.08em;
  font-weight: 600;
  display: block;
  margin-bottom: 12rpx;
}

.param-input {
  font-size: 56rpx;
  font-weight: 700;
  color: var(--ink);
  font-family: 'SF Mono', Consolas, Menlo, monospace;
  background: transparent;
  border: none;
  padding: 0;
  width: 100%;
}

.param-switch-cell {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.param-status {
  font-size: 24rpx;
  font-weight: 500;
  display: block;
  margin-top: 4rpx;
}

.param-status.status-on { color: var(--mint); }
.param-status.status-off { color: var(--ink-quiet); }

/* 错误提示 */
.error-msg {
  color: var(--small-color);
  font-size: 24rpx;
  margin-bottom: 20rpx;
  padding: 0 8rpx;
}

/* 按钮行 */
.btn-row {
  display: flex;
  gap: 16rpx;
}

.btn-reset {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
}

.btn-generate {
  text-align: center;
}

/* 生成按钮包装 & 第几手 */
.btn-generate-wrap {
  flex: 2;
  position: relative;
}

.btn-generate-wrap .btn-generate {
  width: 100%;
  text-align: center;
}

.round-badge {
  position: absolute;
  top: -18rpx;
  left: -4rpx;
  font-size: 26rpx;
  color: var(--mint);
  background: var(--card-soft);
  border: 1rpx solid var(--rule);
  padding: 4rpx 18rpx;
  border-radius: 999rpx;
  font-weight: 600;
  letter-spacing: 0.06em;
}

/* 空状态 */
.empty-text {
  display: block;
  text-align: center;
  color: var(--ink-faint);
  font-size: 28rpx;
  padding: 60rpx 0;
}

/* 结果标题行 */
.result-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.result-header .section-label {
  margin-bottom: 0;
}

/* 数字网格 */
.num-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 32rpx;
}

/* 单个结果：放大居中，直播主视觉 */
.num-grid.single {
  justify-content: center;
  margin: 16rpx 0 40rpx;
}

.num-grid.single .num-cell {
  width: 280rpx;
  height: 280rpx;
  border-radius: 40rpx;
}

.num-grid.single .num-value {
  font-size: 140rpx;
}

.num-grid.single .num-badge {
  font-size: 24rpx;
  top: 16rpx;
  right: 24rpx;
}

.num-grid.single .guan-badge {
  font-size: 32rpx;
  bottom: 16rpx;
  right: 24rpx;
}

.num-cell {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 16rpx;
  font-size: 26rpx;
  font-weight: 600;
  position: relative;
}

.num-cell.big {
  background: var(--big-bg);
  color: var(--big-color);
}

.num-cell.small {
  background: var(--small-bg);
  color: var(--small-color);
}

.num-cell.big.guan {
  background: rgba(76, 175, 80, 0.35);
  color: #a5d6a7;
  box-shadow: 0 0 12rpx rgba(76, 175, 80, 0.3);
}

.num-cell.small.guan {
  background: rgba(239, 83, 80, 0.35);
  color: #ef9a9a;
  box-shadow: 0 0 12rpx rgba(239, 83, 80, 0.3);
}

.guan-badge {
  position: absolute;
  bottom: 2rpx;
  right: 6rpx;
  font-size: 14rpx;
  font-weight: 600;
  color: #ffd54f;
  letter-spacing: 0;
}

.num-badge {
  position: absolute;
  top: 4rpx;
  right: 8rpx;
  font-size: 16rpx;
  font-weight: 500;
}

.num-badge.big {
  color: var(--big-badge);
}

.num-badge.small {
  color: var(--small-badge);
}

/* 统计区 */
.stats-divider {
  border-top: 1rpx solid var(--rule);
  padding-top: 28rpx;
}

.stats-title {
  font-size: 20rpx;
  color: var(--ink-quiet);
  letter-spacing: 0.12em;
  font-weight: 600;
  display: block;
  margin-bottom: 20rpx;
}

.stats-row {
  display: flex;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.stats-cell {
  flex: 1;
  background: var(--card-soft);
  border-radius: 24rpx;
  padding: 28rpx;
  text-align: center;
}

.stats-label {
  font-size: 20rpx;
  letter-spacing: 0.12em;
  font-weight: 600;
  display: block;
  margin-bottom: 10rpx;
}

.stats-label.big { color: var(--big-color); }
.stats-label.small { color: var(--small-color); }

.stats-num {
  font-size: 56rpx;
  font-weight: 600;
  font-family: 'SF Mono', Consolas, Menlo, monospace;
  display: block;
}

.stats-num.big { color: var(--big-color); }
.stats-num.small { color: var(--small-color); }

.stats-pct {
  font-size: 22rpx;
  color: var(--ink-quiet);
  display: block;
  margin-top: 6rpx;
}

/* 求和 */
.sum-section {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: var(--card-soft);
  border-radius: 24rpx;
  padding: 24rpx 28rpx;
  margin-top: 20rpx;
}

.sum-label {
  font-size: 20rpx;
  color: var(--ink-quiet);
  letter-spacing: 0.12em;
  font-weight: 600;
}

.sum-value {
  font-size: 40rpx;
  font-weight: 600;
  color: var(--mint);
  font-family: 'SF Mono', Consolas, Menlo, monospace;
}

/* 比例条 */
.ratio-bar {
  height: 10rpx;
  border-radius: 5rpx;
  overflow: hidden;
  display: flex;
  background: var(--card-soft);
}

.ratio-big {
  background: rgba(76, 175, 80, 0.5);
  transition: width 0.3s ease;
}

.ratio-small {
  background: rgba(239, 83, 80, 0.5);
  transition: width 0.3s ease;
}

/* 历史弹窗 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  z-index: 100;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 48rpx;
}

.modal-panel {
  background: var(--card);
  border-radius: 40rpx;
  padding: 40rpx;
  width: 100%;
  max-height: 70vh;
  border: 1rpx solid var(--rule);
  display: flex;
  flex-direction: column;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.modal-header .section-label {
  margin-bottom: 0;
}

.modal-close {
  color: var(--ink-quiet);
  font-size: 40rpx;
  padding: 8rpx 16rpx;
  line-height: 1;
}

.modal-scroll {
  flex: 1;
  max-height: 50vh;
}

.history-item {
  background: var(--card-soft);
  border-radius: 24rpx;
  padding: 24rpx 28rpx;
  margin-bottom: 16rpx;
}

.history-item:last-child {
  margin-bottom: 0;
}

.history-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.history-params {
  font-size: 24rpx;
  color: var(--ink);
  font-weight: 600;
}

.history-time {
  font-size: 20rpx;
  color: var(--ink-quiet);
}

.history-stats {
  display: flex;
  gap: 12rpx;
  font-size: 22rpx;
  align-items: center;
}

/* 历史数字标签 */
.history-nums {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-bottom: 12rpx;
}

.history-num-tag {
  display: inline-block;
  font-size: 20rpx;
  font-weight: 600;
  padding: 4rpx 14rpx;
  border-radius: 12rpx;
  font-family: 'SF Mono', Consolas, Menlo, monospace;
}

.history-num-tag.big {
  background: var(--big-bg);
  color: var(--big-color);
}

.history-num-tag.small {
  background: var(--small-bg);
  color: var(--small-color);
}

.history-big { color: var(--big-color); }
.history-sep { color: var(--ink-quiet); }
.history-small { color: var(--small-color); }
.history-sum { color: var(--mint); }
.history-dup {
  color: var(--ink-quiet);
  margin-left: auto;
}

.modal-hint {
  text-align: center;
  font-size: 22rpx;
  color: var(--ink-faint);
  padding-top: 20rpx;
  display: block;
}

/* 底部 slogan */
.slogan-section {
  padding: 48rpx 24rpx 32rpx;
  text-align: center;
}

.slogan-divider {
  width: 64rpx;
  height: 2rpx;
  background: var(--rule);
  margin: 0 auto 32rpx;
}

.slogan-text {
  display: block;
  font-size: 22rpx;
  letter-spacing: 0.2em;
  color: var(--ink-quiet);
  font-weight: 500;
  margin-bottom: 12rpx;
}

.slogan-sub {
  display: block;
  font-size: 20rpx;
  color: var(--ink-faint);
  letter-spacing: 0.1em;
}
