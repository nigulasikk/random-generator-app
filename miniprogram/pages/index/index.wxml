<wxs src="./index.wxs" module="utils" />

<!-- 开机动画 -->
<view wx:if="{{splashVisible}}" class="splash {{splashLeaving ? 'splash-leave' : ''}}" bindtap="onSkipSplash">
  <view class="splash-glow"></view>
  <image class="splash-img" src="/assets/yao.png" mode="aspectFit" />
  <text wx:if="{{splashTip}}" class="splash-tip">{{splashTip}}</text>
</view>

<!-- 烟花层 -->
<view wx:if="{{fireworks.length}}" class="fireworks">
  <view
    wx:for="{{fireworks}}"
    wx:for-item="burst"
    wx:key="index"
    class="fw-burst"
    style="left: {{burst.cx}}; top: {{burst.cy}};"
  >
    <view
      wx:for="{{burst.particles}}"
      wx:for-item="p"
      wx:key="index"
      class="fw-particle"
      style="--dx: {{p.dx}}; --dy: {{p.dy}}; background: {{p.color}}; animation-delay: {{p.delay}};"
    ></view>
  </view>
</view>

<view class="page">
  <!-- 活动主视觉 -->
  <view class="hero" bindtap="onReplaySplash">
    <view class="hero-main">
      <text class="hero-title">神秘叔文玩回血</text>
      <view class="hero-tagline">
        <view class="hero-rule"></view>
        <text class="hero-accent">摇摇乐</text>
        <view class="hero-rule"></view>
      </view>
    </view>
  </view>

  <!-- 配置卡片 -->
  <view class="card">
    <view class="section-label section-label-row">
      <view class="section-label-main">
        <view class="section-dot"></view>
        <text>参数设置</text>
      </view>
      <view class="pill-btn" bindtap="onShowHistory">历史记录</view>
    </view>

    <view class="param-grid">
      <view class="param-cell">
        <text class="param-label">最小值</text>
        <input class="param-input" type="number" value="{{minVal}}" bindinput="onMinInput" />
      </view>
      <view class="param-cell">
        <text class="param-label">最大值</text>
        <input class="param-input" type="number" value="{{maxVal}}" bindinput="onMaxInput" />
      </view>
      <view class="param-cell">
        <text class="param-label">生成个数</text>
        <input class="param-input" type="number" value="{{count}}" bindinput="onCountInput" />
      </view>
      <view class="param-cell param-switch-cell">
        <view>
          <text class="param-label">允许重复</text>
          <text class="param-status {{allowDup ? 'status-on' : 'status-off'}}">{{allowDup ? '已开启' : '已关闭'}}</text>
        </view>
        <switch checked="{{allowDup}}" bindchange="onDupChange" color="#45e6a4" />
      </view>
    </view>

    <view wx:if="{{errorMsg}}" class="error-msg">{{errorMsg}}</view>

    <view class="btn-row">
      <view class="pill-btn btn-reset" bindtap="onReset">重置</view>
      <view class="btn-generate-wrap">
        <view class="pill-btn-primary btn-generate" bindtap="onGenerate">生成随机数</view>
        <text wx:if="{{roundCount > 0}}" class="round-badge">第{{roundCount}}手</text>
      </view>
    </view>
  </view>

  <!-- 结果卡片 -->
  <view class="card" wx:if="{{generated}}">
    <view class="result-header">
      <view class="section-label">
        <view class="section-dot"></view>
        <text>生成结果</text>
      </view>
      <view class="pill-btn" bindtap="onCopy">复制结果</view>
    </view>

    <!-- 数字网格 -->
    <view class="num-grid {{results.length === 1 ? 'single' : ''}}">
      <view
        wx:for="{{results}}"
        wx:key="index"
        class="num-cell {{item.isBig ? 'big' : 'small'}} {{item.isGuan ? 'guan' : ''}}"
      >
        <text class="num-value">{{item.value}}</text>
        <text class="num-badge {{item.isBig ? 'big' : 'small'}}">{{item.badge}}</text>
        <text wx:if="{{item.isGuan}}" class="guan-badge">灌</text>
      </view>
    </view>

    <!-- 统计区 -->
    <view class="stats-divider"></view>
    <view class="stats-section">
      <text class="stats-title">大小统计（分界点：{{threshold}}）</text>
      <view class="stats-row">
        <view class="stats-cell">
          <text class="stats-label small">小（{{'<' + threshold}}）</text>
          <text class="stats-num small">{{smallCount}}</text>
          <text class="stats-pct">{{smallPct}}%</text>
        </view>
        <view class="stats-cell">
          <text class="stats-label big">大（≥{{threshold}}）</text>
          <text class="stats-num big">{{bigCount}}</text>
          <text class="stats-pct">{{bigPct}}%</text>
        </view>
      </view>
      <view class="ratio-bar">
        <view class="ratio-small" style="width: {{smallRatio}}%"></view>
        <view class="ratio-big" style="width: {{bigRatio}}%"></view>
      </view>

      <view class="sum-section">
        <text class="sum-label">求和</text>
        <text class="sum-value">{{sumTotal}}</text>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="card" wx:if="{{!generated}}">
    <text class="empty-text">请生成随机数</text>
  </view>

  <!-- 底部 slogan -->
  <view class="slogan-section">
    <view class="slogan-divider"></view>
    <text class="slogan-text">无广告 · 优质交互 · 开源公正</text>
    <text class="slogan-sub">用真诚的代码，让这个世界变得更美好一些。</text>
  </view>

  <!-- 历史记录弹窗 -->
  <view class="modal-mask" wx:if="{{showHistory}}" bindtap="onHideHistory">
    <view class="modal-panel" catchtap="">
      <view class="modal-header">
        <view class="section-label">
          <view class="section-dot"></view>
          <text>历史记录</text>
        </view>
        <text class="modal-close" bindtap="onHideHistory">×</text>
      </view>

      <scroll-view scroll-y class="modal-scroll">
        <view wx:if="{{history.length === 0}}" class="empty-text" style="padding: 40rpx 0;">暂无记录</view>
        <view
          wx:for="{{history}}"
          wx:key="id"
          class="history-item"
          data-record="{{item}}"
          bindtap="onHistoryTap"
        >
          <view class="history-top">
            <view class="history-params-wrap">
              <text wx:if="{{item.roundCount}}" class="history-round">第{{item.roundCount}}手</text>
              <text class="history-params">{{item.minVal}} ~ {{item.maxVal}} × {{item.count}}个</text>
            </view>
            <text class="history-time">{{utils.formatTime(item.timestamp)}}</text>
          </view>
          <view class="history-nums">
            <text
              wx:for="{{item.results}}"
              wx:for-item="r"
              wx:for-index="ri"
              wx:key="ri"
              class="history-num-tag {{r.isBig ? 'big' : 'small'}}"
            >{{r.value}}</text>
          </view>
          <view class="history-stats">
            <text class="history-big">大 {{item.bigCount}}</text>
            <text class="history-sep">|</text>
            <text class="history-small">小 {{item.smallCount}}</text>
            <text class="history-sep">|</text>
            <text class="history-sum">和 {{item.sumTotal}}</text>
            <text class="history-dup">{{item.allowDup ? '允许重复' : '不重复'}}</text>
          </view>
        </view>
      </scroll-view>

      <text class="modal-hint">点击记录可回看完整结果</text>
    </view>
  </view>
</view>
